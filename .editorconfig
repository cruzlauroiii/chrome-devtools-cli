root = true

[*.cs]
indent_style = space
indent_size = 4

dotnet_naming_rule.everything_pascal.severity = error
dotnet_naming_rule.everything_pascal.symbols = all_symbols
dotnet_naming_rule.everything_pascal.style = pascal_style

dotnet_naming_symbols.all_symbols.applicable_kinds = namespace, class, struct, interface, enum, property, method, field, event, delegate, parameter, local, local_function, type_parameter
dotnet_naming_symbols.all_symbols.applicable_accessibilities = *

dotnet_naming_style.pascal_style.capitalization = pascal_case

dotnet_naming_rule.private_fields_pascal.severity = error
dotnet_naming_rule.private_fields_pascal.symbols = private_fields
dotnet_naming_rule.private_fields_pascal.style = pascal_style
dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private, protected, internal

dotnet_naming_rule.locals_pascal.severity = error
dotnet_naming_rule.locals_pascal.symbols = local_symbols
dotnet_naming_rule.locals_pascal.style = pascal_style
dotnet_naming_symbols.local_symbols.applicable_kinds = local, parameter, local_function

dotnet_diagnostic.IDE1006.severity = error
dotnet_diagnostic.SA1300.severity = error
dotnet_diagnostic.SA1306.severity = none
dotnet_diagnostic.SA1312.severity = none
dotnet_diagnostic.SA1313.severity = none
dotnet_diagnostic.SA1101.severity = none
dotnet_diagnostic.SA1633.severity = none
dotnet_diagnostic.SA1200.severity = none
dotnet_diagnostic.SA1208.severity = none
dotnet_diagnostic.SA1516.severity = none
dotnet_diagnostic.SA1600.severity = none
dotnet_diagnostic.SA1601.severity = none
dotnet_diagnostic.SA1602.severity = none
